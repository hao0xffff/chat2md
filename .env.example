APP_NAME=chat-to-markdown
OUTPUT_DIR=./output
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Optional. Leave empty to connect directly.
# HTTP_PROXY=http://127.0.0.1:7890

ENABLED_PLATFORMS=["chatgpt","gemini"]
PLATFORM_URL_PATTERNS={"chatgpt":["chatgpt.com/share"],"gemini":["gemini.google.com/share","g.co/gemini/share"],"doubao":["doubao.com/share","www.doubao.com/share"]}

DEFAULT_EXPORT_FORMAT=ai_readable
DEFAULT_INCLUDE_IMAGES=true
DEFAULT_INCLUDE_METADATA=true
DEFAULT_INCLUDE_FRONTMATTER=true
DEFAULT_CREATE_INDEX=true
DEFAULT_CREATE_MANIFEST=true
DEFAULT_CREATE_MESSAGES=true
