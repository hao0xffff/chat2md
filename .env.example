APP_NAME=chat-to-markdown
DISPLAY_NAME=聊两毛的
ENGLISH_NAME=chat to markdown
OUTPUT_DIR=./output
LOCAL_OUTPUT_DIR=./output
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Optional. Leave empty to connect directly.
# HTTP_PROXY=http://127.0.0.1:7890

ENABLED_PLATFORMS=["chatgpt","gemini"]
PLATFORM_URL_PATTERNS={"chatgpt":["chatgpt.com/share"],"gemini":["gemini.google.com/share","share.gemini.google","g.co/gemini/share"],"doubao":["doubao.com/share","www.doubao.com/share","doubao.com/thread","www.doubao.com/thread"]}

DEFAULT_EXPORT_FORMAT=ai_readable
DEFAULT_INCLUDE_IMAGES=true
DEFAULT_INCLUDE_METADATA=true
DEFAULT_INCLUDE_FRONTMATTER=true
DEFAULT_CREATE_INDEX=true
DEFAULT_CREATE_MANIFEST=true
DEFAULT_CREATE_MESSAGES=true

# Storage. Current writer is local filesystem; object storage fields are reserved
# for deployment/integration configuration and UI/API discovery.
STORAGE_BACKEND=local
ALLOW_CUSTOM_OUTPUT_DIR=true
# Empty means any local custom output path is allowed when ALLOW_CUSTOM_OUTPUT_DIR=true.
# Set roots to restrict absolute custom paths in production.
ALLOWED_OUTPUT_ROOTS=[]
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_PREFIX=chat-to-markdown
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ENV=STORAGE_ACCESS_KEY_ID
OBJECT_STORAGE_SECRET_KEY_ENV=STORAGE_SECRET_ACCESS_KEY

# Task persistence. "file" keeps task status available after service restarts.
TASK_REPOSITORY_BACKEND=file
TASK_REPOSITORY_PATH=output/.chat2md_tasks/tasks.json

# Optional auth metadata when this module is protected by SSO at gateway level.
AUTH_MODE=none
SSO_PROVIDER=
SSO_LOGIN_URL=
